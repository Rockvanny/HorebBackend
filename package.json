{
  "name": "backend-engine",
  "version": "1.0.0",
  "description": "Backend empaquetado para ejecución local",
  "main": "index.js",
  "bin": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "lint": "eslint",
    "migrations:generate": "sequelize-cli migration:generate --name",
    "migrations:run": "sequelize-cli db:migrate",
    "migrations:revert": "sequelize-cli db:migrate:undo",
    "migrations:delete": "sequelize-cli db:migrate:undo:all",
    "build:bin": "pkg . --targets node14-win-x64 --output dist/api-service.exe"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "pkg": {
    "assets": [
      "routes/**/*.js",
      "middlewares/**/*.js",
      "schemas/**/*.js",
      "services/**/*.js",
      "config/**/*.js",
      "db/**/*.js",
      ".env"
    ]
  },
  "devDependencies": {
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^3.4.1",
    "nodemon": "^3.1.9",
    "prettier": "^2.3.2"
  },
  "dependencies": {
    "@hapi/boom": "^9.1.4",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^10.0.0",
    "express": "^4.21.2",
    "faker": "^5.5.3",
    "fs-extra": "^11.3.4",
    "joi": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.14.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.7.1",
    "pg-hstore": "^2.3.4",
    "semver": "^7.7.1",
    "sequelize": "^6.6.5",
    "sequelize-cli": "^6.2.0",
    "serialize-javascript": "^7.0.5",
    "socket.io": "^4.8.1",
    "umzug": "^3.8.2",
    "winston": "^3.19.0"
  },
  "engines": {
    "node": "14.x"
  }
}
